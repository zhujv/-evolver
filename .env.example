# 复制为 `.env` 后填写（勿提交真实密钥）。启动时由 `load_application_dotenv` 自动加载。

# --- 大模型（任选其一）---
# 直连 Anthropic / OpenAI（未配置 EVOLVER_API_BASE 时使用）
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# OpenRouter（OpenAI 兼容：设置 API 基址 + 密钥；模型名如 anthropic/claude-3.5-sonnet）
# EVOLVER_API_BASE=https://openrouter.ai/api/v1
# EVOLVER_API_KEY=
# EVOLVER_MAIN_MODEL=anthropic/claude-3.5-sonnet
# EVOLVER_PROXY_TYPE=openai

# 或仅设置 OPENROUTER_API_KEY，并在 ~/.evolver/config.json 的 api.providers 里配置 endpoint（见 README）

# --- 后端 HTTP / 安全 ---
# EVOLVER_PORT=16888
# EVOLVER_HTTP_HOST=127.0.0.1
# 与前端 / 脚本请求头一致；不设则开发模式下部分 RPC 不校验令牌
# EVOLVER_SERVER_TOKEN=

# --- 可选：仅允许访问某目录（沙箱）---
# EVOLVER_LOCAL_FS_ROOT=

# --- 可选：在绑定非本机地址时显式允许 bash 工具 ---
# EVOLVER_ALLOW_EXEC_SHELL=1

# --- 日志 ---
# EVOLVER_PYTHON_LOG=evolver-python.log
